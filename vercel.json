{
  "version": 2,
  "name": "vega-academy",

  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/downloads/(.*)", "dest": "/downloads/$1" },
    { "src": "/blog/(.*)", "dest": "/blog/$1" },
    { "src": "/starter-kit/(.*)", "dest": "/starter-kit/$1" },
    { "src": "/course/(.*)", "dest": "/course/$1" },
    { "src": "/tools/(.*)", "dest": "/tools/$1" },
    { "src": "/templates/(.*)", "dest": "/templates/$1" },
    { "src": "/foundations/(.*)", "dest": "/foundations/$1" },
    { "src": "/pro/(.*)", "dest": "/pro/$1" },
    { "src": "/certification/(.*)", "dest": "/certification/$1" },
    { "src": "/membership/(.*)", "dest": "/membership/$1" },
    { "src": "/about/(.*)", "dest": "/about/$1" },
    { "src": "/contact/(.*)", "dest": "/contact/$1" },
    { "src": "/thank-you/(.*)", "dest": "/thank-you/$1" },
    { "src": "/pricing/(.*)", "dest": "/pricing/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
